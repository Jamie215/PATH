---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description, wide = false } = Astro.props;
const fullTitle = title === 'PATH' ? 'PATH — Pain Assessment Tools Hub' : `${title} · PATH`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? 'Pain Assessment Tools Hub'} />
    <title>{fullTitle}</title>

    <!-- Google Material Symbols (icons) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
    />
  </head>
  <body>
    <header class="site-header">
      <div class={`container ${wide ? 'container--wide' : ''}`}>
        <a href="/" class="site-header__brand">
          <span class="site-header__mark">PATH</span>
          <span class="site-header__tagline">Pain Assessment Tools Hub</span>
        </a>
      </div>
    </header>

    <main class={`container ${wide ? 'container--wide' : ''}`}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class={`container ${wide ? 'container--wide' : ''}`}>
        <small>PATH · Pain Assessment Tools Hub</small>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    margin-bottom: var(--space-7);
    background: var(--color-bg);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-3);
    color: var(--color-text);
    border-bottom: none;
  }
  .site-header__brand:hover { border-bottom: none; }

  .site-header__mark {
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.04em;
    color: var(--color-primary);
  }

  .site-header__tagline {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  main {
    min-height: 60vh;
    padding-bottom: var(--space-8);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-5) 0;
    color: var(--color-text-subtle);
  }

  @media (max-width: 480px) {
    .site-header__tagline { display: none; }
  }
</style>