---
import Base from '../layouts/Base.astro';
import { assessments } from '../assessments/registry';
---
<Base title="PATH" description="Pain Assessment Tools Hub — a collection of validated assessment tools.">
  <script is:inline>
     if (typeof window !== 'undefined' && window.sessionStorage) {
       window.sessionStorage.removeItem('path:assessment-context');
     }
   </script>
  <section class="picker" aria-labelledby="picker-heading">
    <h1 id="picker-heading" class="picker__heading">Select the Tool You'd Like to Use</h1>

    <ul class="picker__grid">
      {assessments.map((a) => {
        const isAvailable = a.status === 'available';
        const Tag = isAvailable ? 'a' : 'div';
        const props = isAvailable ? { href: `/${a.slug}/` } : {};
        return (
          <li class={`tool-card tool-card--${a.status}`}>
            <Tag class="tool-card__inner" {...props}>
              <span class="tool-card__icon material-symbols-outlined" aria-hidden="true">
                {a.icon}
              </span>
              <h2 class="tool-card__title">{a.title}</h2>
              <p class="tool-card__desc">{a.description}</p>
              {!isAvailable && (
                <span class="tool-card__pill">Coming soon</span>
              )}
            </Tag>
          </li>
        );
      })}
    </ul>
  </section>
</Base>

<style>
  .picker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: var(--space-6);
  }

  .picker__heading {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    text-align: center;
    margin: 0 0 var(--space-7) 0;
  }

  /* Horizontal carousel of fixed-size cards; scrolls within its own track
     so the page body never scrolls sideways. */
  .picker__grid {
    list-style: none;
    margin: 0;
    padding: var(--space-2) var(--space-1) var(--space-5);
    display: flex;
    gap: var(--space-5);
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-left: var(--space-1);
    -webkit-overflow-scrolling: touch;
  }

  .tool-card {
    flex: 0 0 240px;
    /* Drop the auto min-size so long content can't stretch the fixed width. */
    min-width: 0;
    scroll-snap-align: start;
  }

  .tool-card__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-5);
    background: var(--color-primary);
    color: #ffffff;
    border-radius: var(--radius-lg);
    border: none;
    /* Fixed width (from .tool-card) + stretched height keeps every card the
       same size; height equalizes to the tallest card via align-items. */
    width: 100%;
    height: 100%;
    min-height: 240px;
    overflow: hidden;
    justify-content: center;
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
    box-shadow: var(--shadow-sm);
  }

  /* Available cards: anchor element, interactive */
  a.tool-card__inner:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-bottom: none;
  }
  a.tool-card__inner:active {
    background: var(--color-primary-active);
    transform: translateY(0);
  }

  /* Planned cards: div, non-interactive but still branded */
  div.tool-card__inner {
    cursor: not-allowed;
    opacity: 0.92;
  }

  .tool-card__icon {
    font-size: 56px;
    color: #ffffff;
    margin-bottom: var(--space-2);
    /* Material Symbols variable font axes */
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 48;
  }

  .tool-card__title {
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0;
    line-height: 1.3;
  }

  .tool-card__desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.82);
    margin: 0;
    line-height: 1.4;
  }

  .tool-card__pill {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: 2px var(--space-2);
    background: rgba(255, 255, 255, 0.18);
    color: #ffffff;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  /* Small screens: drop the carousel for a narrow single column. */
  @media (max-width: 560px) {
    .picker__grid {
      flex-direction: column;
      align-items: center;
      overflow-x: visible;
      scroll-snap-type: none;
      padding-bottom: var(--space-4);
    }
    .tool-card {
      flex: 0 0 auto;
      width: 100%;
      max-width: 280px;
    }
  }
</style>